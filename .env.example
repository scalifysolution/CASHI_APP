# Copy to .env and set your merchant portal URL (opened in-app after Start Cashi / Register sale).
MERCHANT_PORTAL_URL=https://cashi.app

# External store signup URL (opened in the system browser from Settings / menu “Start Cashi on your Store”).
STORE_SIGNUP_URL=https://www.ufff.com

# Cashi backend base URL (should include `/api`).
API_BASE_URL=https://cashi-staging-backend.vercel.app/api

# Optional: reverse + forward geocoding on Home (must match babel.config.js `include` — see repo).
# Google Cloud: enable "Geocoding API" for this key. Restart Metro with --reset-cache after changing.
GOOGLE_MAPS_API_KEY=
